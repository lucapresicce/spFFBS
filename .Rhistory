eps <- sqrt(c_gt) * matrix(rnorm(n_gt * q_gt), n_gt, q_gt) %*% t(L_Sig_gt)
Y_all_gt[, , t]  <- P_t %*% theta_gt[, , t] + eps
}
# G per v1: (np x np x T+tnew) identità
G_all_gt <- array(0, dim = c(np_gt, np_gt, T_gt + tnew_gt))
for (t in seq_len(T_gt + tnew_gt)) G_all_gt[, , t] <- diag(np_gt)
Y_train_gt <- Y_all_gt[, , seq_len(T_gt)]
X_train_gt <- X_all_gt[, , seq_len(T_gt)]
P_train_gt <- P_all_gt[, , seq_len(T_gt)]
G_train_gt <- G_all_gt[, , seq_len(T_gt)]
# Prior v1 (full C0)
m0_gt   <- matrix(0, np_gt, q_gt);  C0_gt <- diag(np_gt)
prior_v1_gt <- list(m = m0_gt, C = C0_gt, nu = q_gt + 1L, Psi = diag(q_gt))
# Prior v2 (block form, stesso C0)
prior_v2_gt <- make_prior_v2(m0_gt, C0_gt, q_gt + 1L, diag(q_gt), p_gt)
grid_gt <- list(tau = c(0.7, 0.8, 0.9), phi = c(6.0, 8.0, 10.0))
par_grid_gt <- spBPS:::expand_grid_cpp(rev(grid_gt$tau), rev(grid_gt$phi))
# — v1 —
cat("[ Sezione 13 ] v1: forward filter + backward sampling + forecast ...\n")
gc(full = TRUE)
t0 <- proc.time()["elapsed"]
out_gt_v1 <- spFFBS:::spFFBS(
Y = Y_train_gt, G = G_all_gt, P = P_all_gt, D = D_gt,
grid = grid_gt, prior = prior_v1_gt,
do_BS = TRUE, do_forecast = TRUE, tnew = tnew_gt,
L = L_gt
)
t_v1_gt <- proc.time()["elapsed"] - t0
cat(sprintf("  v1 completata in %.2f s\n", t_v1_gt))
# — v2 —
cat("[ Sezione 13 ] v2: forward filter + backward sampling + forecast ...\n")
gc(full = TRUE)
seed_rng_v2(runif(1), runif(1))
t0 <- proc.time()["elapsed"]
out_gt_v2 <- spFFBS_v2(
Y = Y_train_gt, X = X_train_gt, D = D_gt,
grid = grid_gt, prior = prior_v2_gt,
do_BS = TRUE, do_forecast = TRUE, tnew = tnew_gt, X_all = X_all_gt,
L = L_gt, n_threads = 1L
)
t_v2_gt <- proc.time()["elapsed"] - t0
cat(sprintf("  v2 completata in %.2f s\n", t_v2_gt))
cat(sprintf("  Speedup pipeline: %.2fx\n\n", t_v1_gt / t_v2_gt))
# ============================================================
# SEZIONE 14 — Metriche di smoothing: v1 vs v2 vs ground truth
# ============================================================
# Per ogni (g, k, t): media posteriore, 2.5° e 97.5° percentile.
# CRPS via formula degli order statistics (O(L log L) per elemento).
.compute_smooth_metrics <- function(BS_list, theta_true_arr, T, np, q) {
theta_hat <- array(0, dim = c(np, q, T))
theta_lo  <- array(0, dim = c(np, q, T))
theta_hi  <- array(0, dim = c(np, q, T))
crps_t    <- numeric(T)
for (t in seq_len(T)) {
samp <- BS_list[[t]]
for (g in seq_len(np)) for (k in seq_len(q)) {
sv <- samp[g, k, ]
theta_hat[g, k, t] <- mean(sv)
theta_lo[g, k, t]  <- quantile(sv, 0.025)
theta_hi[g, k, t]  <- quantile(sv, 0.975)
}
cr <- sapply(seq_len(np), function(g) sapply(seq_len(q), function(k) {
sv <- samp[g, k, ];  y <- theta_true_arr[g, k, t]
xs <- sort(sv);  L2 <- length(xs)
mean(abs(sv - y)) - sum(xs * (2*seq_len(L2) - L2 - 1L)) / L2^2
}))
crps_t[t] <- mean(cr)
}
list(
rmse     = sqrt(mean((theta_hat - theta_true_arr)^2)),
bias     = mean(theta_hat - theta_true_arr),
coverage = mean((theta_true_arr >= theta_lo) & (theta_true_arr <= theta_hi)),
width    = mean(theta_hi - theta_lo),
crps     = mean(crps_t)
)
}
theta_true_train <- theta_gt[, , seq_len(T_gt)]
sm_v1 <- .compute_smooth_metrics(out_gt_v1$BS, theta_true_train, T_gt, np_gt, q_gt)
sm_v2 <- .compute_smooth_metrics(out_gt_v2$BS, theta_true_train, T_gt, np_gt, q_gt)
cat("=== Metriche di Smoothing (backward sampling) ===\n")
cat(sprintf("  %-10s  %-12s  %-12s\n", "Metrica", "v1", "v2"))
cat("  ------------------------------------\n")
cat(sprintf("  %-10s  %-12.6f  %-12.6f\n", "RMSE",     sm_v1$rmse,     sm_v2$rmse))
cat(sprintf("  %-10s  %-12.6f  %-12.6f\n", "Bias",     sm_v1$bias,     sm_v2$bias))
cat(sprintf("  %-10s  %-12.4f  %-12.4f   (nominale 0.95)\n",
"Coverage", sm_v1$coverage, sm_v2$coverage))
cat(sprintf("  %-10s  %-12.6f  %-12.6f\n", "CI width", sm_v1$width,    sm_v2$width))
cat(sprintf("  %-10s  %-12.6f  %-12.6f\n", "CRPS",     sm_v1$crps,     sm_v2$crps))
cat("\n")
# ============================================================
# SEZIONE 15 — Metriche di previsione: v1 vs v2 (h step in avanti)
# ============================================================
.forecast_metrics_h <- function(Y_pred_arr, Y_true_h, n, q) {
Y_hat <- apply(Y_pred_arr, c(1, 2), mean)
Y_med <- apply(Y_pred_arr, c(1, 2), median)
Y_lo  <- apply(Y_pred_arr, c(1, 2), quantile, 0.025)
Y_hi  <- apply(Y_pred_arr, c(1, 2), quantile, 0.975)
crps_v <- sapply(seq_len(n), function(g) {
mean(sapply(seq_len(q), function(k) {
sv <- Y_pred_arr[g, k, ];  y <- Y_true_h[g, k]
xs <- sort(sv);  L2 <- length(xs)
mean(abs(sv - y)) - sum(xs * (2*seq_len(L2) - L2 - 1L)) / L2^2
}))
})
list(
rmse     = sqrt(mean((Y_hat - Y_true_h)^2)),
mae      = mean(abs(Y_med - Y_true_h)),
coverage = mean((Y_true_h >= Y_lo) & (Y_true_h <= Y_hi)),
crps     = mean(crps_v)
)
}
# v1 forecast: out_gt_v1$forecast$Y_pred è n x q x L x (T+tnew)
Y_pred_v1 <- out_gt_v1$forecast$Y_pred
# v2 forecast: stessa struttura
Y_pred_v2 <- out_gt_v2$forecast$Y_pred
cat("=== Metriche di Previsione (h step in avanti) ===\n")
cat(sprintf("  %-4s  %-10s %-10s  %-10s %-10s  %-10s %-10s  %-10s %-10s\n",
"h",
"RMSE_v1", "RMSE_v2",
"MAE_v1",  "MAE_v2",
"Cov_v1",  "Cov_v2",
"CRPS_v1", "CRPS_v2"))
cat("  ", paste(rep("-", 88), collapse = ""), "\n", sep = "")
for (h in seq_len(tnew_gt)) {
Y_true_h <- Y_all_gt[, , T_gt + h]
m1 <- .forecast_metrics_h(Y_pred_v1[, , , T_gt + h], Y_true_h, n_gt, q_gt)
m2 <- .forecast_metrics_h(Y_pred_v2[, , , T_gt + h], Y_true_h, n_gt, q_gt)
cat(sprintf("  h=%-2d  %-10.4f %-10.4f  %-10.4f %-10.4f  %-10.4f %-10.4f  %-10.4f %-10.4f\n",
h,
m1$rmse, m2$rmse,
m1$mae,  m2$mae,
m1$coverage, m2$coverage,
m1$crps, m2$crps))
}
cat("\n")
# ============================================================
# SEZIONE 16 — Profiling su dimensioni elevate
# ============================================================
# Obiettivo: capire se il costo scala come O(n³) (dominato da
# Cholesky di Q — limite algoritmico) o se c'è overhead residuo
# eliminabile. Misura per-step e scaling in n.
# ── 16a: Dataset n=500, T=50 ─────────────────────────────────
set.seed(123)
n16 <- 500L;  T16 <- 50L;  p16 <- 2L;  q16 <- 3L;  L16 <- 200L
coords16 <- matrix(runif(n16 * 2), ncol = 2)
D16      <- spBPS:::arma_dist(coords16)
X16      <- array(rnorm(n16 * p16 * T16), dim = c(n16, p16, T16))
Y16      <- array(rnorm(n16 * q16 * T16, sd = 0.5), dim = c(n16, q16, T16))
prior16 <- make_prior_v2(
m0   = matrix(0, n16 + p16, q16),
C0   = diag(n16 + p16),
nu0  = q16 + 1L,
Psi0 = diag(q16),
p    = p16
)
par_grid16 <- spBPS:::expand_grid_cpp(rev(c(0.7, 0.8, 0.9)), rev(c(1, 2, 4)))
# Forward filter — 1 thread
gc(full = TRUE)
seed_rng_v2(runif(1), runif(1))
t0 <- proc.time()["elapsed"]
ff16 <- spFF3_v2(Y = Y16, X = X16, D = D16, par_grid = par_grid16,
prior = prior16, G_beta = diag(p16), rho = 1.0,
num_threads = 1L)
t_ff16_1 <- proc.time()["elapsed"] - t0
cat(sprintf("n=%d T=%d  FF  1thr : %.3f s  [%.2f ms/step]\n",
n16, T16, t_ff16_1,
t_ff16_1 / (T16 * nrow(par_grid16)) * 1e3))
# Forward filter — 5 thread
gc(full = TRUE)
seed_rng_v2(runif(1), runif(1))
t0 <- proc.time()["elapsed"]
ff16_5 <- spFF3_v2(Y = Y16, X = X16, D = D16, par_grid = par_grid16,
prior = prior16, G_beta = diag(p16), rho = 1.0,
num_threads = 5L)
t_ff16_5 <- proc.time()["elapsed"] - t0
cat(sprintf("n=%d T=%d  FF  5thr : %.3f s  [speedup vs 1thr: %.2fx]\n",
n16, T16, t_ff16_5, t_ff16_1 / t_ff16_5))
# Backward sampling
Wg16 <- matrix(rep(1/nrow(par_grid16), nrow(par_grid16)))
gc(full = TRUE)
seed_rng_v2(runif(1), runif(1))
t0 <- proc.time()["elapsed"]
bs16 <- weighted_backward_sample_T_v2(
G_beta = diag(p16), rho = 1.0, D = D16,
ForwFilt = ff16, L = L16,
par_grid = par_grid16, weights = Wg16, num_threads = 1L)
t_bs16_1 <- proc.time()["elapsed"] - t0
cat(sprintf("n=%d T=%d  BS  1thr : %.3f s  [%.2f ms/step]\n\n",
n16, T16, t_bs16_1,
t_bs16_1 / T16 * 1e3))
# ── 16b: Scaling in n — verifica O(n³) ───────────────────────
# Se il costo per step scala come n³, il Cholesky di Q domina.
# Se scala più velocemente, c'è overhead da allocazioni residue.
# Teorico: raddoppiare n → 8x il costo per step.
cat("Scaling in n (FF, 1 thread, T=20, J=9):\n")
cat(sprintf("  %-6s  %-10s  %-14s  %-10s\n",
"n", "tot (s)", "ms/step", "ratio vs n=100"))
t_ref <- NA
for (nn in c(100L, 200L, 300L, 500L)) {
set.seed(1)
Tn <- 20L
Dn  <- spBPS:::arma_dist(matrix(runif(nn * 2), ncol = 2))
Xn  <- array(rnorm(nn * 2L * Tn), dim = c(nn, 2L, Tn))
Yn  <- array(rnorm(nn * 3L * Tn, sd = 0.5), dim = c(nn, 3L, Tn))
prn <- make_prior_v2(matrix(0, nn+2L, 3L), diag(nn+2L), 4L, diag(3L), 2L)
pgn <- spBPS:::expand_grid_cpp(rev(c(0.7, 0.8, 0.9)), rev(c(1, 2, 4)))
gc(full = TRUE)
seed_rng_v2(runif(1), runif(1))
t0  <- proc.time()["elapsed"]
spFF3_v2(Y=Yn, X=Xn, D=Dn, par_grid=pgn, prior=prn,
G_beta=diag(2L), rho=1.0, num_threads=1L)
tt  <- proc.time()["elapsed"] - t0
ms_step <- tt / (Tn * nrow(pgn)) * 1e3
if (is.na(t_ref)) t_ref <- ms_step
cat(sprintf("  n=%-4d  %-10.3f  %-14.3f  %.2fx\n",
nn, tt, ms_step, ms_step / t_ref))
}
cat("\n")
# Atteso se O(n³): n=200 → 8x, n=300 → 27x, n=500 → 125x vs n=100.
# Se il ratio osservato è più basso → overhead da allocazioni su n grande.
# Se il ratio è più alto → il Cholesky è già il bottleneck assoluto.
# ── 16c: Profiling backward sampler a n grande ───────────────
# Verifica se OPT-L (block Schur) riduce il tempo di BS a n=500
# rispetto alla versione senza (impossibile misurare direttamente,
# ma si stima dal confronto con n=200 e scaling teorico).
# BS dovrebbe scalare come O(n³) per step (Schur complement n×n).
cat("Scaling in n (BS, 1 thread, T=20, L=50, J=9):\n")
cat(sprintf("  %-6s  %-10s  %-14s\n", "n", "tot (s)", "ms/step"))
for (nn in c(100L, 200L, 300L, 500L)) {
set.seed(2)
Tn <- 20L
Dn  <- spBPS:::arma_dist(matrix(runif(nn * 2), ncol = 2))
Xn  <- array(rnorm(nn * 2L * Tn), dim = c(nn, 2L, Tn))
Yn  <- array(rnorm(nn * 3L * Tn, sd = 0.5), dim = c(nn, 3L, Tn))
prn <- make_prior_v2(matrix(0, nn+2L, 3L), diag(nn+2L), 4L, diag(3L), 2L)
pgn <- spBPS:::expand_grid_cpp(rev(c(0.7,0.8,0.9)), rev(c(1,2,4)))
Wgn <- matrix(rep(1/9, 9))
gc(full = TRUE)
seed_rng_v2(runif(1), runif(1))
ffn <- spFF3_v2(Y=Yn, X=Xn, D=Dn, par_grid=pgn, prior=prn,
G_beta=diag(2L), rho=1.0, num_threads=1L)
gc(full = TRUE)
seed_rng_v2(runif(1), runif(1))
t0 <- proc.time()["elapsed"]
weighted_backward_sample_T_v2(
G_beta=diag(2L), rho=1.0, D=Dn, ForwFilt=ffn,
L=50L, par_grid=pgn, weights=Wgn, num_threads=1L)
tt <- proc.time()["elapsed"] - t0
cat(sprintf("  n=%-4d  %-10.3f  %-14.3f\n",
nn, tt, tt / Tn * 1e3))
}
cat("\n")
# ── 16d: Thread scaling a n=500 ──────────────────────────────
cat("Thread scaling a n=500, T=50 (FF):\n")
for (nth in c(1L, 2L, 3L, 4L, 5L)) {
gc(full = TRUE)
seed_rng_v2(runif(1), runif(1))
t0 <- proc.time()["elapsed"]
out <- spFF3_v2(Y=Y16, X=X16, D=D16, par_grid=par_grid16,
prior=prior16, G_beta=diag(p16), rho=1.0,
num_threads=nth)
el <- proc.time()["elapsed"] - t0
cat(sprintf("  %d thr: %.3f s  (speedup vs 1thr: %.2fx)\n",
nth, el, t_ff16_1 / el))
}
cat("\n")
cat("Thread scaling a n=500, T=50 (BS, L=100):\n")
t_bs16_nth <- numeric(5)
for (nth in c(1L, 2L, 3L, 4L, 5L)) {
gc(full = TRUE)
seed_rng_v2(runif(1), runif(1))
t0 <- proc.time()["elapsed"]
out <- weighted_backward_sample_T_v2(
G_beta=diag(p16), rho=1.0, D=D16,
ForwFilt=ff16, L=L16,
par_grid=par_grid16, weights=Wg16, num_threads=nth)
el <- proc.time()["elapsed"] - t0
t_bs16_nth[nth] <- el
cat(sprintf("  %d thr: %.3f s  (speedup vs 1thr: %.2fx)\n",
nth, el, t_bs16_1 / el))
}
# ============================================================
# SEZIONE 17 — Stress test: spFFBS() vs spFFBS_v2() — pipeline completa
# ============================================================
# Confronto end-to-end sulla funzione che sarà pubblicata.
# Le sezioni precedenti testavano funzioni interne (spFF3, BS, ecc.);
# qui si misura solo la pipeline esposta all'utente.
# ── Dataset comune: n=100, T=30, L=100 (piccolo, entrambe le versioni) ──
set.seed(100)
n_p <- 100L;  T_p <- 30L;  p_p <- 2L;  q_p <- 3L;  L_p <- 100L
np_p <- n_p + p_p
grid_p <- list(tau = c(0.7, 0.8, 0.9), phi = c(1.0, 2.0, 4.0))
coords_p <- matrix(runif(n_p * 2), ncol = 2)
D_p      <- spBPS:::arma_dist(coords_p)
X_p      <- array(rnorm(n_p * p_p * T_p), dim = c(n_p, p_p, T_p))
Y_p      <- array(rnorm(n_p * q_p * T_p, sd = 0.5), dim = c(n_p, q_p, T_p))
P_p <- array(0, dim = c(n_p, np_p, T_p))
G_p <- array(0, dim = c(np_p, np_p, T_p))
for (t in seq_len(T_p)) { P_p[,,t] <- cbind(X_p[,,t], diag(n_p)); G_p[,,t] <- diag(np_p) }
m0_p   <- matrix(0, np_p, q_p);  C0_p <- diag(np_p)
pv1_p  <- list(m=m0_p, C=C0_p, nu=q_p+1L, Psi=diag(q_p))
pv2_p  <- make_prior_v2(m0_p, C0_p, q_p+1L, diag(q_p), p_p)
cat("=== Pipeline n=100 T=30 L=100 (do_BS=TRUE) ===\n")
gc(full=TRUE)
t0 <- proc.time()["elapsed"]
out <- spFFBS::spFFBS(Y=Y_p, G=G_p, P=P_p, D=D_p, grid=grid_p, prior=pv1_p,
do_BS=TRUE, L=L_p)
t_v1_p <- proc.time()["elapsed"] - t0
cat(sprintf("  spFFBS   v1 : %.3f s\n", t_v1_p))
gc(full=TRUE)
seed_rng_v2(runif(1), runif(1))
t0 <- proc.time()["elapsed"]
out <- spFFBS_v2(Y=Y_p, X=X_p, D=D_p, grid=grid_p, prior=pv2_p,
do_BS=TRUE, L=L_p, n_threads=1L, verbose=FALSE)
t_v2_p1 <- proc.time()["elapsed"] - t0
cat(sprintf("  spFFBS_v2 1thr: %.3f s  [speedup: %.2fx]\n", t_v2_p1, t_v1_p/t_v2_p1))
gc(full=TRUE)
seed_rng_v2(runif(1), runif(1))
t0 <- proc.time()["elapsed"]
out <- spFFBS_v2(Y=Y_p, X=X_p, D=D_p, grid=grid_p, prior=pv2_p,
do_BS=TRUE, L=L_p, n_threads=5L, verbose=FALSE)
t_v2_p5 <- proc.time()["elapsed"] - t0
cat(sprintf("  spFFBS_v2 5thr: %.3f s  [speedup vs v1: %.2fx]\n\n", t_v2_p5, t_v1_p/t_v2_p5))
# ── Dataset medio: n=200, T=30, L=100 ──────────────────────────────────
set.seed(200)
n_m <- 200L;  T_m <- 30L;  p_m <- 2L;  q_m <- 3L;  L_m <- 100L
np_m <- n_m + p_m
grid_m <- list(tau = c(0.7, 0.8, 0.9), phi = c(1.0, 2.0, 4.0))
coords_m <- matrix(runif(n_m * 2), ncol = 2)
D_m      <- spBPS:::arma_dist(coords_m)
X_m      <- array(rnorm(n_m * p_m * T_m), dim = c(n_m, p_m, T_m))
Y_m      <- array(rnorm(n_m * q_m * T_m, sd = 0.5), dim = c(n_m, q_m, T_m))
P_m <- array(0, dim = c(n_m, np_m, T_m))
G_m <- array(0, dim = c(np_m, np_m, T_m))
for (t in seq_len(T_m)) { P_m[,,t] <- cbind(X_m[,,t], diag(n_m)); G_m[,,t] <- diag(np_m) }
m0_m  <- matrix(0, np_m, q_m);  C0_m <- diag(np_m)
pv1_m <- list(m=m0_m, C=C0_m, nu=q_m+1L, Psi=diag(q_m))
pv2_m <- make_prior_v2(m0_m, C0_m, q_m+1L, diag(q_m), p_m)
cat("=== Pipeline n=200 T=30 L=100 (do_BS=TRUE) ===\n")
gc(full=TRUE)
t0 <- proc.time()["elapsed"]
out <- spFFBS::spFFBS(Y=Y_m, G=G_m, P=P_m, D=D_m, grid=grid_m, prior=pv1_m,
do_BS=TRUE, L=L_m)
t_v1_m <- proc.time()["elapsed"] - t0
cat(sprintf("  spFFBS   v1 : %.3f s\n", t_v1_m))
gc(full=TRUE)
seed_rng_v2(runif(1), runif(1))
t0 <- proc.time()["elapsed"]
out <- spFFBS_v2(Y=Y_m, X=X_m, D=D_m, grid=grid_m, prior=pv2_m,
do_BS=TRUE, L=L_m, n_threads=1L, verbose=FALSE)
t_v2_m1 <- proc.time()["elapsed"] - t0
cat(sprintf("  spFFBS_v2 1thr: %.3f s  [speedup: %.2fx]\n", t_v2_m1, t_v1_m/t_v2_m1))
gc(full=TRUE)
seed_rng_v2(runif(1), runif(1))
t0 <- proc.time()["elapsed"]
out <- spFFBS_v2(Y=Y_m, X=X_m, D=D_m, grid=grid_m, prior=pv2_m,
do_BS=TRUE, L=L_m, n_threads=5L, verbose=FALSE)
t_v2_m5 <- proc.time()["elapsed"] - t0
cat(sprintf("  spFFBS_v2 5thr: %.3f s  [speedup vs v1: %.2fx]\n\n", t_v2_m5, t_v1_m/t_v2_m5))
rm(G_m, P_m);  gc(full=TRUE)
# ── v2 only: n=500 (v1 non gestibile — G+P cube ~36 GB a T=30) ─────────
set.seed(500)
n_l <- 500L;  T_l <- 20L;  p_l <- 2L;  q_l <- 3L;  L_l <- 100L
grid_l <- list(tau = c(0.7, 0.8, 0.9), phi = c(1.0, 2.0, 4.0))
D_l   <- spBPS:::arma_dist(matrix(runif(n_l*2), ncol=2))
X_l   <- array(rnorm(n_l*p_l*T_l), dim=c(n_l, p_l, T_l))
Y_l   <- array(rnorm(n_l*q_l*T_l, sd=0.5), dim=c(n_l, q_l, T_l))
pv2_l <- make_prior_v2(matrix(0, n_l+p_l, q_l), diag(n_l+p_l), q_l+1L, diag(q_l), p_l)
cat("=== spFFBS_v2 only — n=500 T=20 L=100 (v1 non gestibile) ===\n")
cat(sprintf("  (v1 richiederebbe G+P cube: %.1f GB)\n",
((n_l+p_l)^2 + n_l*(n_l+p_l)) * T_l * 8 / 1e9))
for (nth in c(1L, 5L)) {
gc(full=TRUE)
seed_rng_v2(runif(1), runif(1))
t0 <- proc.time()["elapsed"]
out <- spFFBS_v2(Y=Y_l, X=X_l, D=D_l, grid=grid_l, prior=pv2_l,
do_BS=TRUE, L=L_l, n_threads=nth, verbose=FALSE)
el <- proc.time()["elapsed"] - t0
cat(sprintf("  spFFBS_v2 %dthr: %.3f s\n", nth, el))
gc(full=TRUE)
}
# ============================================================
# SEZIONE 18 — Metriche di previsione temporale: RMSPE e Coverage
# ============================================================
# Riusa out_gt_v1, out_gt_v2, Y_all_gt dalla sezione 13.
cat("=== Metriche Previsione Temporale (h step avanti) ===\n")
cat(sprintf("  %-4s  %-10s %-10s  %-10s %-10s\n",
"h", "RMSPE_v1", "RMSPE_v2", "Cov_v1", "Cov_v2"))
cat("  --------------------------------------------------\n")
for (h in seq_len(tnew_gt)) {
Y_true_h <- Y_all_gt[, , T_gt + h]
Yp_v1    <- out_gt_v1$forecast$Y_pred[, , , T_gt + h]   # n x q x L
Yp_v2    <- out_gt_v2$forecast$Y_pred[, , , T_gt + h]
Yhat_v1 <- apply(Yp_v1, c(1,2), mean)
Yhat_v2 <- apply(Yp_v2, c(1,2), mean)
Ylo_v1  <- apply(Yp_v1, c(1,2), quantile, 0.025)
Yhi_v1  <- apply(Yp_v1, c(1,2), quantile, 0.975)
Ylo_v2  <- apply(Yp_v2, c(1,2), quantile, 0.025)
Yhi_v2  <- apply(Yp_v2, c(1,2), quantile, 0.975)
rmspe_v1 <- sqrt(mean((Yhat_v1 - Y_true_h)^2))
rmspe_v2 <- sqrt(mean((Yhat_v2 - Y_true_h)^2))
cov_v1   <- mean((Y_true_h >= Ylo_v1) & (Y_true_h <= Yhi_v1))
cov_v2   <- mean((Y_true_h >= Ylo_v2) & (Y_true_h <= Yhi_v2))
cat(sprintf("  h=%-2d  %-10.4f %-10.4f  %-10.4f %-10.4f\n",
h, rmspe_v1, rmspe_v2, cov_v1, cov_v2))
}
cat("\n")
# ============================================================
# SEZIONE 19 — Interpolazione spaziale: RMSPE e Coverage
# ============================================================
# NOTA sulla sezione precedente: la coverage bassa (37.5%) era
# dovuta a phi_gt=8 (correlazione spaziale a cortissimo raggio).
# Con phi=8 i siti test sono statisticamente indipendenti dai
# siti training, e la varianza di w accumula per T=30 passi
# (~30× maggiore della kernel prior). Qui usiamo phi_sp=1 per
# avere correlazione a lungo raggio e confronto calibrato.
set.seed(303)
phi_sp  <- 1.0    # long-range correlation: exp(-1*0.5) ~ 0.60 at median dist
tau_sp  <- 0.80
c_sp    <- (1 - tau_sp) / tau_sp
T_sp    <- 20L;  p_sp <- 2L;  q_sp <- 3L
L_sp    <- 200L; n_sp <- 80L
Sigma_sp <- matrix(c(1.0, -0.3, 0.2, -0.3, 1.2, 0.1, 0.2, 0.1, 0.8),
q_sp, q_sp)
L_Sig_sp <- t(chol(Sigma_sp))
# Coordinate — same split 80/20
coords_sp <- matrix(runif(n_sp * 2), ncol = 2)
n_test_sp <- floor(0.2 * n_sp)
n_tr_sp   <- n_sp - n_test_sp
idx_test_sp <- sample(seq_len(n_sp), n_test_sp, replace = FALSE)
idx_tr_sp   <- setdiff(seq_len(n_sp), idx_test_sp)
coords_tr_sp <- coords_sp[idx_tr_sp,   , drop = FALSE]
coords_te_sp <- coords_sp[idx_test_sp, , drop = FALSE]
D_tr_sp    <- spBPS:::arma_dist(coords_tr_sp)
D_te_sp    <- spBPS:::arma_dist(coords_te_sp)
D_te_tr_sp <- spBPS:::arma_dist(rbind(coords_te_sp, coords_tr_sp))[
seq_len(n_test_sp), n_test_sp + seq_len(n_tr_sp)]
K_full_sp <- exp(-phi_sp * spBPS:::arma_dist(coords_sp))
L_K_sp    <- t(chol(K_full_sp))
K_tr_sp   <- K_full_sp[idx_tr_sp, idx_tr_sp]
# Genera stati e osservazioni con phi_sp=1
np_sp <- n_sp + p_sp
theta_sp <- array(0, dim = c(np_sp, q_sp, T_sp))
for (t in seq(2, T_sp)) {
eta_b <- matrix(rnorm(p_sp * q_sp), p_sp, q_sp) %*% t(L_Sig_sp)
eta_w <- L_K_sp %*% matrix(rnorm(n_sp * q_sp), n_sp, q_sp) %*% t(L_Sig_sp)
theta_sp[seq_len(p_sp), , t]        <- theta_sp[seq_len(p_sp), , t-1] + eta_b
theta_sp[p_sp + seq_len(n_sp), , t] <- theta_sp[p_sp + seq_len(n_sp), , t-1] + eta_w
}
X_all_sp <- array(runif(n_sp * p_sp * T_sp), dim = c(n_sp, p_sp, T_sp))
Y_all_sp  <- array(0, dim = c(n_sp, q_sp, T_sp))
for (t in seq_len(T_sp)) {
P_t <- cbind(X_all_sp[, , t], diag(n_sp))
eps <- sqrt(c_sp) * matrix(rnorm(n_sp * q_sp), n_sp, q_sp) %*% t(L_Sig_sp)
Y_all_sp[, , t] <- P_t %*% theta_sp[, , t] + eps
}
Y_tr_sp <- Y_all_sp[idx_tr_sp,   , ]
X_tr_sp <- X_all_sp[idx_tr_sp,   , ]
grid_sp <- list(tau = c(0.7, 0.8, 0.9), phi = c(0.5, 1.0, 2.0))
par_grid_sp <- spBPS:::expand_grid_cpp(rev(grid_sp$tau), rev(grid_sp$phi))
pr_sp_v2 <- make_prior_v2(
m0   = matrix(0, n_tr_sp + p_sp, q_sp),
C0   = rbind(cbind(diag(0.005, p_sp), matrix(0, p_sp, n_tr_sp)),
cbind(matrix(0, n_tr_sp, p_sp), K_tr_sp)),
nu0  = q_sp + 1L,
Psi0 = diag(q_sp),
p    = p_sp
)
cat(sprintf("Spatial hold-out: n_train=%d, n_test=%d, phi=%.1f, T=%d\n\n",
n_tr_sp, n_test_sp, phi_sp, T_sp))
seed_rng_v2(runif(1), runif(1))
ff_sp <- spFF3_v2(Y=Y_tr_sp, X=X_tr_sp, D=D_tr_sp,
par_grid=par_grid_sp, prior=pr_sp_v2,
G_beta=diag(p_sp), rho=1.0, num_threads=1L)
Wi_sp <- compute_Wt_v2(ff_sp, tau=grid_sp$tau, phi=grid_sp$phi,
n_threads=1L, verbose=FALSE)
Wg_sp <- colMeans(Wi_sp)
cat("=== Metriche Interpolazione Spaziale per t ===\n")
cat(sprintf("  %-5s  %-10s  %-8s  %-10s\n", "t", "RMSPE", "Coverage", "CI_width"))
cat("  ------------------------------------------\n")
for (t_pick in c(5L, 10L, T_sp)) {
Wg_mat <- matrix(rep(Wg_sp, t_pick - 1L),
nrow = length(Wg_sp), ncol = t_pick - 1L)
Xu_t   <- matrix(X_all_sp[idx_test_sp, , t_pick],
nrow = n_test_sp, ncol = p_sp)
si_t <- spatial_interpolation_v2(
G_beta=diag(p_sp), rho=1.0, Xu=Xu_t,
D_s=D_tr_sp, D_u=D_te_sp, D_us=D_te_tr_sp,
par_grid=par_grid_sp, ForwFilt=ff_sp,
weights=Wg_mat, t=t_pick, L=L_sp, num_threads=1L)
si_arr <- array(0, dim=c(n_test_sp, q_sp, L_sp))
for (l in seq_len(L_sp))
si_arr[,,l] <- si_t[[l]][seq_len(n_test_sp), , drop=FALSE]
Y_hat_t  <- apply(si_arr, c(1,2), mean)
Y_lo_t   <- apply(si_arr, c(1,2), quantile, 0.025)
Y_hi_t   <- apply(si_arr, c(1,2), quantile, 0.975)
Y_obs_t  <- Y_all_sp[idx_test_sp, , t_pick]
rmspe_t <- sqrt(mean((Y_hat_t - Y_obs_t)^2))
cov_t   <- mean((Y_obs_t >= Y_lo_t) & (Y_obs_t <= Y_hi_t))
wid_t   <- mean(Y_hi_t - Y_lo_t)
cat(sprintf("  t=%-4d  %-10.4f  %-8.4f  %-10.4f\n",
t_pick, rmspe_t, cov_t, wid_t))
}
cat("\n")
gc()
gc()
library(spFFBS)   # v1 già installato
library(spBPS)    # per arma_dist, expand_grid_cpp
# Compila e carica v2 (solo la prima volta, o dopo modifiche al .cpp)
Rcpp::sourceCpp("src/FFBS-DYNBPS-struct-v2.cpp")
gc()
gc()
